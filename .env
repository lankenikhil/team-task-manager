# ============================================================
# MongoDB Atlas Connection URI
# ============================================================
# Replace <db_password> with your actual MongoDB Atlas database password.
# Example: mongodb+srv://lankenikhil25_db_user:myPassword123@cluster0...
# IMPORTANT: Never commit your actual password to version control.
# On Vercel, set this in Project Settings > Environment Variables.
# ============================================================
MONGODB_URI=mongodb+srv://lankenikhil25_db_user:<db_password>@cluster0.pvfnrjd.mongodb.net/team-task-manager?retryWrites=true&w=majority

# JWT Secret for authentication token signing
# IMPORTANT: Change this to a strong secret in production
JWT_SECRET=937045

# App URL (used for production cookie settings)
NEXT_PUBLIC_APP_URL=http://localhost:3000
